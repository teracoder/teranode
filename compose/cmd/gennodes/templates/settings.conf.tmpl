{{- /* Generated by compose/cmd/gennodes - DO NOT EDIT */ -}}
# Auto-generated overlay for a multinode teranode network ({{ .NodeCount }} nodes).
# Generated by compose/cmd/gennodes. Mounted into each container as
# /app/settings_local.conf. Stacks on top of /app/settings.conf via the
# context-layered settings system.

{{- range .Nodes }}

# === teranode{{ .Index }} ===
clientName.docker.teranode{{ .Index }}                         = teranode{{ .Index }}
coinbase_arbitrary_text.docker.teranode{{ .Index }}            = /teranode{{ .Index }}/
blockchainDB.docker.teranode{{ .Index }}                       = teranode{{ .Index }}
blockchainDBUserPwd.docker.teranode{{ .Index }}                = miner{{ .Index }}
blockchain_store.docker.teranode{{ .Index }}.test              = postgres://miner{{ .Index }}:miner{{ .Index }}@postgres:${POSTGRES_PORT}/teranode{{ .Index }}
aerospike_host.docker.teranode{{ .Index }}                     = aerospike-{{ .Index }}
aerospike_port.docker.teranode{{ .Index }}                     = {{ .AerospikeServicePort }}
utxostore.docker.teranode{{ .Index }}.test                     = aerospike://aerospike-{{ .Index }}:{{ .AerospikeServicePort }}/test?set=utxo&WarmUp=32&ConnectionQueueSize=32&LimitConnectionsToQueueSize=true&MinConnectionsPerNode=8&externalStore=file://${DATADIR}/external
p2p_peer_id.docker.teranode{{ .Index }}                        = {{ .PeerID }}
p2p_private_key.docker.teranode{{ .Index }}                    = {{ .PrivateKey }}
p2p_static_peers.docker.teranode{{ .Index }}                   = {{ .StaticPeers }}
p2p_bootstrap_peers.docker.teranode{{ .Index }}.test           =
{{- end }}

# Shared: disable DHT bootstrap chatter for the local mesh; static peers are enough.
p2p_dht_mode = "client"
p2p_allow_private_ips = true
