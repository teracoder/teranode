#!/usr/bin/env bash
# Generated by compose/cmd/gennodes - generate blocks on the {{ .NodeCount }}-node stack.
#
# Usage:
#   ./generate-blocks.sh <node>,<count> [<node>,<count> ...]
#
# Examples:
#   ./generate-blocks.sh 1,10              # 10 blocks on node 1
#   ./generate-blocks.sh 1,5 3,5           # 5 on node 1, then 5 on node 3
#   ./generate-blocks.sh 1,10,2,5,3,5      # same as: 1,10 2,5 3,5

set -euo pipefail

RPC_USER="bitcoin"
RPC_PASS="bitcoin"

# node index -> host RPC port
declare -A RPC_PORTS=(
{{- range .Nodes }}
  [{{ .Index }}]={{ .RPCPort }}
{{- end }}
)

generate() {
  local node=$1 count=$2
  local port=${RPC_PORTS[$node]:-}
  if [[ -z "$port" ]]; then
    echo "error: unknown node $node (valid: {{ range .Nodes }}{{ .Index }} {{ end }})" >&2
    return 1
  fi

  echo "generating $count block(s) on teranode$node (localhost:$port)..."
  local resp
  resp=$(curl --silent --fail --user "$RPC_USER:$RPC_PASS" \
    -X POST "http://localhost:$port" \
    -H "Content-Type: application/json" \
    -d "{\"method\": \"generate\", \"params\": [$count]}" 2>&1) || {
    echo "  failed: $resp" >&2
    return 1
  }

  local generated
  generated=$(echo "$resp" | grep -o '"[0-9a-f]\{64\}"' | wc -l)
  echo "  $generated block(s) generated"
}

if [[ $# -eq 0 ]]; then
  echo "usage: $0 <node>,<count> [<node>,<count> ...]"
  echo "  e.g. $0 1,10 3,5   or   $0 1,10,3,5"
  exit 2
fi

# Flatten all args into one comma-separated string, then split into pairs.
flat=$(IFS=,; echo "$*")
IFS=',' read -ra tokens <<< "$flat"

if (( ${#tokens[@]} % 2 != 0 )); then
  echo "error: odd number of values - expected <node>,<count> pairs" >&2
  exit 2
fi

for (( i=0; i<${#tokens[@]}; i+=2 )); do
  generate "${tokens[i]}" "${tokens[i+1]}"
done
