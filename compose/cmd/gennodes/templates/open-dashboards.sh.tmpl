#!/usr/bin/env bash
# Generated by compose/cmd/gennodes - opens all {{ .NodeCount }} teranode dashboards.

open_url() {
    if command -v xdg-open &>/dev/null; then
        xdg-open "$1"
    elif command -v open &>/dev/null; then
        open "$1"
    else
        echo "$1"
    fi
}
{{ range .Nodes }}
open_url "http://localhost:{{ .DashboardPort }}"
{{- end }}
