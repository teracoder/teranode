{{- /* Generated by compose/cmd/gennodes - DO NOT EDIT */ -}}
# Auto-generated docker-compose for a multinode teranode network ({{ .NodeCount }} nodes).
# Generated by compose/cmd/gennodes. Regenerate with: make gen-multinode N={{ .NodeCount }}

networks:
  teranode-network:
    name: teranode-network-multinode-${TEST_ID:-default}

services:
  teranode-builder:
    container_name: teranode-builder-multinode
    image: teranode:latest
    networks:
      - teranode-network
    build:
      context: ../..
      dockerfile: Dockerfile
      args:
        BASE_IMG: ghcr.io/bsv-blockchain/teranode-base:build-latest
        RUN_IMG: ghcr.io/bsv-blockchain/teranode-base:run-latest
    entrypoint: ["true"]

  postgres:
    container_name: postgres-multinode
    image: postgres:latest
    networks:
      - teranode-network
    environment:
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: really_strong_password_change_me
      POSTGRES_DB: postgres
    ports:
      - "15432:5432"
    expose:
      - "5432"
    volumes:
      - ./postgres/init-multinode.sql:/docker-entrypoint-initdb.d/init.sql
    restart: on-failure
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres"]
      interval: 5s
      timeout: 5s
      retries: 5

  kafka-shared:
    container_name: kafka-shared-multinode
    image: redpandadata/redpanda:latest
    networks:
      - teranode-network
    mem_limit: 256m
    command:
      - redpanda start
      - --smp 1
      - --overprovisioned
      - --node-id 0
      - --kafka-addr PLAINTEXT://0.0.0.0:9092
      - --advertise-kafka-addr PLAINTEXT://kafka-shared:9092
      - --pandaproxy-addr 0.0.0.0:9093
      - --advertise-pandaproxy-addr localhost:9093
    expose:
      - "8081"
      - "9092"
      - "9093"

  jaeger:
    container_name: jaeger-multinode
    image: jaegertracing/all-in-one:1.59
    networks:
      - teranode-network
    environment:
      - COLLECTOR_ZIPKIN_HOST_PORT=:9411
{{- range .Nodes }}

  aerospike-{{ .Index }}:
    container_name: aerospike-{{ .Index }}-multinode
    image: aerospike/aerospike-server:8.0
    networks:
      - teranode-network
    command: --config-file /etc/aerospike.conf
    # aerospike.conf requests proto-fd-max=15000; without this override the
    # container inherits docker's 1024 default and aerospike aborts at
    # startup with "system file descriptors not enough".
    ulimits:
      nofile:
        soft: 65536
        hard: 65536
    ports:
      - "{{ .AerospikeServicePort }}:{{ .AerospikeServicePort }}"
    expose:
      - "{{ .AerospikeServicePort }}"
    volumes:
      - ./aerospike/aerospike-{{ .Index }}.conf:/etc/aerospike.conf
      - ../../data/multinode/aerospike{{ .Index }}/logs:/var/log/aerospike
      - ../../data/multinode/aerospike{{ .Index }}/data:/opt/aerospike/data
{{- end }}
{{- range .Nodes }}

  teranode{{ .Index }}:
    container_name: teranode{{ .Index }}-multinode
    image: teranode:latest
    cap_add:
      - NET_ADMIN
    networks:
      - teranode-network
    depends_on:
      postgres:
        condition: service_healthy
      kafka-shared:
        condition: service_started
      aerospike-{{ .Index }}:
        condition: service_started
    entrypoint:
      [
        "/app/wait.sh", "aerospike-{{ .Index }}", "{{ .AerospikeServicePort }}", "2", "--",
        "/app/wait.sh", "postgres", "5432", "0", "--",
        "/app/wait.sh", "kafka-shared", "9092", "0", "--",
        "/app/teranode.run", "-localTestStartFromState=RUNNING"
      ]
    environment:
      SETTINGS_CONTEXT: "docker.teranode{{ .Index }}.test"
      JAEGER_SERVICE_NAME: teranode{{ .Index }}
      JAEGER_AGENT_HOST: jaeger
      JAEGER_AGENT_PORT: 6831
      logLevel: "DEBUG"
      KAFKA_BLOCKS: blocks-teranode{{ .Index }}
      KAFKA_BLOCKS_FINAL: blocks-final-teranode{{ .Index }}
      KAFKA_INVALID_BLOCKS: invalid-blocks-teranode{{ .Index }}
      KAFKA_INVALID_SUBTREES: invalid-subtrees-teranode{{ .Index }}
      KAFKA_LEGACY_INV: legacy-inv-teranode{{ .Index }}
      KAFKA_REJECTEDTX: rejectedtx-teranode{{ .Index }}
      KAFKA_SUBTREES: subtrees-teranode{{ .Index }}
      KAFKA_TXMETA: txmeta-teranode{{ .Index }}
      KAFKA_VALIDATORTXS: validatortxs-teranode{{ .Index }}
    volumes:
      - ../../settings.conf:/app/settings.conf
      - ./settings_multinode.conf:/app/settings_local.conf
      - ../../data/multinode/teranode{{ .Index }}/txstore:/app/data/txstore
      - ../../data/multinode/teranode{{ .Index }}/subtreestore:/app/data/subtreestore
      - ../../data/multinode/teranode{{ .Index }}/blockstore:/app/data/blockstore
      - ../../data/multinode/teranode{{ .Index }}/subtree_quorum:/app/data/subtree_quorum
      - ../../data/multinode/teranode{{ .Index }}/external:/app/data/external
      - ../wait.sh:/app/wait.sh
    ports:
{{- range .HostPorts }}
      - "{{ .Host }}:{{ .Container }}"
{{- end }}
    expose:
      - "8000"
      - "8081-8092"
      - "8094-8097"
      - "8099"
      - "9091"
      - "9905"
      - "9292"
{{- end }}
