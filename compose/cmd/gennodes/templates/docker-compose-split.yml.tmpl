{{- /* Generated by compose/cmd/gennodes - DO NOT EDIT */ -}}
# Auto-generated docker-compose for a multinode teranode network ({{ .NodeCount }} nodes).
# Split topology: each logical node is decomposed into one container per
# microservice so chaos commands can target individual services (kill, pause,
# isolate, slow) without bringing down the whole node.
#
# Services per node ({{ len .SplitServices }}): {{ range $i, $s := .SplitServices }}{{ if $i }}, {{ end }}{{ $s.Name }}{{ end }}.
# The 'core' sidecar bundles rpc/alert/blockpersister/utxopersister/pruner/legacy
# so RPC stays reachable and ancillary services aren't stranded.
#
# Regenerate with: compose/multinode.sh up {{ .NodeCount }} -allinone=0

networks:
  teranode-network:
    name: teranode-network-multinode-${TEST_ID:-default}

services:
  teranode-builder:
    container_name: teranode-builder-multinode
    image: teranode:latest
    networks:
      - teranode-network
    build:
      context: ../..
      dockerfile: Dockerfile
      args:
        BASE_IMG: ghcr.io/bsv-blockchain/teranode-base:build-latest
        RUN_IMG: ghcr.io/bsv-blockchain/teranode-base:run-latest
    entrypoint: ["true"]

  postgres:
    container_name: postgres-multinode
    image: postgres:latest
    networks:
      - teranode-network
    environment:
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: really_strong_password_change_me
      POSTGRES_DB: postgres
    ports:
      - "15432:5432"
    expose:
      - "5432"
    volumes:
      - ./postgres/init-multinode.sql:/docker-entrypoint-initdb.d/init.sql
    restart: on-failure
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres"]
      interval: 5s
      timeout: 5s
      retries: 5

  kafka-shared:
    container_name: kafka-shared-multinode
    image: redpandadata/redpanda:latest
    networks:
      - teranode-network
    mem_limit: 256m
    command:
      - redpanda start
      - --smp 1
      - --overprovisioned
      - --node-id 0
      - --kafka-addr PLAINTEXT://0.0.0.0:9092
      - --advertise-kafka-addr PLAINTEXT://kafka-shared:9092
      - --pandaproxy-addr 0.0.0.0:9093
      - --advertise-pandaproxy-addr localhost:9093
    expose:
      - "8081"
      - "9092"
      - "9093"

  jaeger:
    container_name: jaeger-multinode
    image: jaegertracing/all-in-one:1.59
    networks:
      - teranode-network
    environment:
      - COLLECTOR_ZIPKIN_HOST_PORT=:9411
{{- range .Nodes }}

  aerospike-{{ .Index }}:
    container_name: aerospike-{{ .Index }}-multinode
    image: aerospike/aerospike-server:8.0
    networks:
      - teranode-network
    command: --config-file /etc/aerospike.conf
    # aerospike.conf requests proto-fd-max=15000; without this override the
    # container inherits docker's 1024 default and aerospike aborts at
    # startup with "system file descriptors not enough".
    ulimits:
      nofile:
        soft: 65536
        hard: 65536
    ports:
      - "{{ .AerospikeServicePort }}:{{ .AerospikeServicePort }}"
    expose:
      - "{{ .AerospikeServicePort }}"
    volumes:
      - ./aerospike/aerospike-{{ .Index }}.conf:/etc/aerospike.conf
      - ../../data/multinode/aerospike{{ .Index }}/logs:/var/log/aerospike
      - ../../data/multinode/aerospike{{ .Index }}/data:/opt/aerospike/data
{{- end }}
{{- /*
  Per-node service block, parameterised on $svc (splitService). All 9 services
  per node share: SETTINGS_CONTEXT, the kafka topic env vars, the data volume
  mounts, postgres/kafka/aerospike depends_on, and the wait.sh entrypoint
  prefix. They differ only on: container name suffix, entrypoint flag(s),
  cap_add (p2p only), host port mappings, expose list, and an optional
  blockchain-as-dependency hint to bias startup ordering. Single source of
  truth for the service list lives in main.go's buildSplitServices().
*/}}
{{- range $node := .Nodes }}
{{- range $svc := $.SplitServices }}

  teranode{{ $node.Index }}-{{ $svc.Name }}:
    container_name: teranode{{ $node.Index }}-{{ $svc.Name }}-multinode
    image: teranode:latest
{{- if $svc.NeedsNetAdmin }}
    cap_add:
      - NET_ADMIN
{{- end }}
    networks:
      - teranode-network
    depends_on:
      postgres:
        condition: service_healthy
      kafka-shared:
        condition: service_started
      aerospike-{{ $node.Index }}:
        condition: service_started
{{- if $svc.DependsOnBlockchain }}
      teranode{{ $node.Index }}-blockchain:
        condition: service_healthy
{{- end }}
    entrypoint:
      [
        "/app/wait.sh", "aerospike-{{ $node.Index }}", "{{ $node.AerospikeServicePort }}", "2", "--",
        "/app/wait.sh", "postgres", "5432", "0", "--",
        "/app/wait.sh", "kafka-shared", "9092", "0", "--",
        "/app/teranode.run", "-all=0",{{ range $svc.EntrypointFlags }} "{{ . }}",{{ end }} "-localTestStartFromState=RUNNING"
      ]
    environment:
      SETTINGS_CONTEXT: "docker.teranode{{ $node.Index }}.test"
      JAEGER_SERVICE_NAME: teranode{{ $node.Index }}-{{ $svc.Name }}
      JAEGER_AGENT_HOST: jaeger
      JAEGER_AGENT_PORT: 6831
      logLevel: "DEBUG"
      KAFKA_BLOCKS: blocks-teranode{{ $node.Index }}
      KAFKA_BLOCKS_FINAL: blocks-final-teranode{{ $node.Index }}
      KAFKA_INVALID_BLOCKS: invalid-blocks-teranode{{ $node.Index }}
      KAFKA_INVALID_SUBTREES: invalid-subtrees-teranode{{ $node.Index }}
      KAFKA_LEGACY_INV: legacy-inv-teranode{{ $node.Index }}
      KAFKA_REJECTEDTX: rejectedtx-teranode{{ $node.Index }}
      KAFKA_SUBTREES: subtrees-teranode{{ $node.Index }}
      KAFKA_TXMETA: txmeta-teranode{{ $node.Index }}
      KAFKA_VALIDATORTXS: validatortxs-teranode{{ $node.Index }}
    volumes:
      - ../../settings.conf:/app/settings.conf
      - ./settings_multinode.conf:/app/settings_local.conf
      - ../wait.sh:/app/wait.sh
{{- range $mount := $svc.DataMounts }}
      - ../../data/multinode/teranode{{ $node.Index }}/{{ $mount }}:/app/data/{{ $mount }}
{{- end }}
    # Host port = HostBase + (container - 8000). All split-service container
    # ports must be >= 8000; a sub-8000 port would map to a wrong or negative
    # host port and collide across nodes. Lowest listener today is 8000
    # (HEALTH_CHECK_PORT) so the invariant holds — preserve it when adding
    # new entries to buildSplitServices in compose/cmd/gennodes/main.go.
    ports:
{{- range $port := $svc.HostPorts }}
      - "{{ add $node.HostBase (sub $port 8000) }}:{{ $port }}"
{{- end }}
    expose:
{{- range $port := $svc.ExposePorts }}
      - "{{ $port }}"
{{- end }}
{{- if $svc.HealthcheckPort }}
    healthcheck:
      # nc -z confirms the TCP listener is accepting connections. grpc-go's
      # Server.Serve binds the listener AND wires the handler in one call, so
      # this is a reliable proxy for "service is ready". start_period gives
      # the daemon a quiet first 5s to bind the port without retries counting
      # against the failure budget; after that, interval=2s × retries=30 caps
      # wait-for-healthy at ~60s.
      test: ["CMD-SHELL", "nc -z localhost {{ $svc.HealthcheckPort }}"]
      interval: 2s
      timeout: 2s
      retries: 30
      start_period: 5s
{{- end }}
{{- end }}
{{- end }}
